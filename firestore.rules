rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only accept the exact 5-character code format this app generates
    // (uppercase letters/digits, excluding 0/O/1/I) — rejects arbitrary
    // document ids someone might try to write directly.
    function isValidRoomCode(code) {
      return code is string && code.matches('^[ABCDEFGHJKLMNPQRSTUVWXYZ23456789]{5}$');
    }

    // One document per live match room, keyed by the 5-character edit code.
    match /snookerRooms/{roomId} {
      allow read: if isValidRoomCode(roomId);
      allow create, update: if isValidRoomCode(roomId)
                              && request.resource.data.keys().hasAll(['json', 'version'])
                              && request.resource.data.json is string
                              && request.resource.data.json.size() < 200000
                              && request.resource.data.version is number
                              && (!('viewCode' in request.resource.data)
                                  || request.resource.data.viewCode == null
                                  || isValidRoomCode(request.resource.data.viewCode))
                              // Auto-expiry field for the Firestore TTL policy: must be a
                              // timestamp no more than ~24h1m in the future, so clients can't
                              // set it further out and keep a room alive indefinitely.
                              && (!('expireAt' in request.resource.data)
                                  || (request.resource.data.expireAt is timestamp
                                      && request.resource.data.expireAt <= request.time + duration.value(24, 'h') + duration.value(1, 'm')));
      allow delete: false;
    }

    // Maps a view-only code to its room's edit code.
    match /snookerViewLinks/{viewCode} {
      allow read: if isValidRoomCode(viewCode);
      allow create: if isValidRoomCode(viewCode)
                      && request.resource.data.keys().hasAll(['roomId'])
                      && request.resource.data.roomId is string
                      && isValidRoomCode(request.resource.data.roomId);
      allow update, delete: false;
    }
  }
}
